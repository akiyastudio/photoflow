{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://photoflow.local/schemas/team-retouch-model-result.json",
  "title": "Team Retouch Model Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "route",
    "image_id",
    "image_size",
    "instances",
    "timing",
    "model_versions"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "route": { "enum": ["S0", "S1", "S2", "S1-C", "S1-S"] },
    "image_id": { "type": "string", "minLength": 1 },
    "image_size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "instances": {
      "type": "array",
      "items": { "$ref": "#/$defs/instance" }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_ms", "inference_ms"],
      "properties": {
        "total_ms": { "type": "number", "minimum": 0 },
        "inference_ms": { "type": "number", "minimum": 0 },
        "peak_vram_mb": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "model_versions": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "box": {
      "type": ["array", "null"],
      "prefixItems": [
        { "type": "number" },
        { "type": "number" },
        { "type": "number" },
        { "type": "number" }
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "instance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "person_id",
        "face_box",
        "visible_body_box",
        "full_body_box",
        "crop_box",
        "mask_path",
        "scores",
        "auto_accepted",
        "conflict_reasons"
      ],
      "properties": {
        "person_id": { "type": "string", "minLength": 1 },
        "face_box": { "$ref": "#/$defs/box" },
        "visible_body_box": { "$ref": "#/$defs/box" },
        "full_body_box": { "$ref": "#/$defs/box" },
        "crop_box": { "$ref": "#/$defs/box" },
        "mask_path": { "type": ["string", "null"] },
        "keypoints_path": { "type": ["string", "null"] },
        "scores": {
          "type": "object",
          "additionalProperties": false,
          "required": ["face", "body", "mask", "association"],
          "properties": {
            "face": { "$ref": "#/$defs/score" },
            "body": { "$ref": "#/$defs/score" },
            "mask": { "$ref": "#/$defs/score" },
            "association": { "$ref": "#/$defs/score" }
          }
        },
        "auto_accepted": { "type": "boolean" },
        "conflict_reasons": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
