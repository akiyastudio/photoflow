{
  "name": "photoflow",
  "productName": "photoflow",
  "private": true,
  "version": "26.7.17",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "generate:icon": "node scripts/generate-app-icon.cjs",
    "build:shell-thumbnail": "node scripts/build-shell-thumbnail.cjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:python": "node scripts/prepare-ffmpeg.cjs && node scripts/build-python.cjs",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron": "npm run build:shell-thumbnail && wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"npm run electron\"",
    "electron:build": "npm run generate:icon && npm run build && npm run build:python && npm run build:shell-thumbnail && electron-builder"
  },
  "build": {
    "appId": "com.photoflow.toolkit",
    "icon": "build/icon.ico",
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "node_modules/exiftool-vendored.exe/**/*",
      "node_modules/exiftool-vendored.pl/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "extraResources": [
        {
          "from": "python/dist/tools.exe",
          "to": "python/tools.exe"
        },
        {
          "from": "python/dist/thumbnail-image-worker.exe",
          "to": "python/thumbnail-image-worker.exe"
        },
        {
          "from": "python/dist/ffmpeg.zip",
          "to": "python/ffmpeg.zip"
        },
        {
          "from": "electron/bin/shell-thumbnail.exe",
          "to": "shell-thumbnail.exe"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "photoflow"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.photography",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Please allow access",
        "NSPhotoLibraryUsageDescription": "需要访问照片以进行整理"
      },
      "extraResources": [
        {
          "from": "python/dist/tools",
          "to": "python/tools"
        },
        {
          "from": "python/dist/thumbnail-image-worker",
          "to": "python/thumbnail-image-worker"
        },
        {
          "from": "python/dist/ffmpeg.zip",
          "to": "python/ffmpeg.zip"
        }
      ]
    },
    "extraResources": [
      {
        "from": "python/birthdays.json",
        "to": "python/birthdays.json"
      }
    ]
  },
  "dependencies": {
    "exiftool-vendored": "^30.5.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^24.10.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.1",
    "electron-builder": "^26.0.12",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "globals": "^15.14.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.46.4",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
