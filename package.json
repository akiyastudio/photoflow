{
  "name": "photoflow-toolkit",
  "private": true,
  "version": "25.12.27",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:python": "cd python && pyinstaller --onefile --clean --name classify classify.py && pyinstaller --onefile --clean --name png_to_jpg png_to_jpg.py && pyinstaller --onefile --clean --name research research.py && pyinstaller --onefile --clean --name catch catch.py && pyinstaller --onefile --clean --name rename rename.py",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"npm run electron\"",
    "electron:build": "npm run build && npm run build:python && electron-builder"
  },
  "build": {
    "appId": "com.photoflow.toolkit",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "dir"
    },
    "extraResources": [
      {
        "from": "python/dist/classify.exe",
        "to": "python/classify.exe"
      },
      {
        "from": "python/dist/png_to_jpg.exe",
        "to": "python/png_to_jpg.exe"
      },
      {
        "from": "python/dist/research.exe",
        "to": "python/research.exe"
      },
      {
        "from": "python/dist/catch.exe",
        "to": "python/catch.exe"
      },
      {
        "from": "python/dist/rename.exe",
        "to": "python/rename.exe"
      },
      {
        "from": "python/birthdays.json",
        "to": "python/birthdays.json"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.1",
    "electron-builder": "^26.0.12",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
