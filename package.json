{
  "name": "photoflow",
  "private": true,
  "version": "26.7.15",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:python": "cd python && pyinstaller --onefile --clean --name classify classify.py && pyinstaller --onefile --clean --name png_to_jpg png_to_jpg.py && pyinstaller --onefile --clean --name research research.py && pyinstaller --onefile --clean --name catch catch.py && pyinstaller --onefile --clean --name cut_video cut_video.py && pyinstaller --onefile --clean --name rename rename.py",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"npm run electron\"",
    "electron:build": "npm run build && npm run build:python && electron-builder"
  },
  "build": {
    "appId": "com.photoflow.toolkit",
    "directories": {
      "output": "release" 
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": ["nsis", "zip"] ,
      "extraResources": [
        { "from": "python/dist/classify.exe", "to": "python/classify.exe" },
        { "from": "python/dist/png_to_jpg.exe", "to": "python/png_to_jpg.exe" },
        { "from": "python/dist/research.exe", "to": "python/research.exe" },
        { "from": "python/dist/catch.exe", "to": "python/catch.exe" },
        { "from": "python/dist/rename.exe", "to": "python/rename.exe" },
        { "from": "python/dist/cut_video.exe", "to": "python/cut_video.exe" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Photoflow"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.photography",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Please allow access",
        "NSPhotoLibraryUsageDescription": "需要访问照片以进行整理"
      },
      "extraResources": [
        { "from": "python/dist/classify", "to": "python/classify" },
        { "from": "python/dist/png_to_jpg", "to": "python/png_to_jpg" },
        { "from": "python/dist/research", "to": "python/research" },
        { "from": "python/dist/catch", "to": "python/catch" },
        { "from": "python/dist/rename", "to": "python/rename" },
        { "from": "python/dist/cut_video", "to": "python/cut_video" }
      ]
    },
    "extraResources": [
      {
        "from": "python/birthdays.json",
        "to": "python/birthdays.json"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.1",
    "electron-builder": "^26.0.12",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
